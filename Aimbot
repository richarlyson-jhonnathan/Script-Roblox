-- === FUNÇÕES DE JOGO ===

local function getLocalPlayer() return Players.LocalPlayer end

local function getPlayerTeam(player)
    if player then
        if player.Team then return player.Team end
        for _, child in ipairs(player:GetChildren()) do
            if child:IsA("ObjectValue") and child.Name == "Team" then return child.Value end
            if child:IsA("StringValue") and child.Name == "Team" then return child.Value end
        end
    end
    return nil
end

local function getHeadPart(character)
    if character then
        for _, part in ipairs(character:GetDescendants()) do
            if part:IsA("BasePart") then
                local nameLower = part.Name:lower()
                if nameLower:find("head") then return part end
            end
        end
        for _, part in ipairs(character:GetDescendants()) do
            if part:IsA("BasePart") then
                local nameLower = part.Name:lower()
                if nameLower:find("neck") then return part end
            end
        end
    end
    return nil
end

local function getChestPart(character)
    if character then
        for _, part in ipairs(character:GetDescendants()) do
            if part:IsA("BasePart") then
                local nameLower = part.Name:lower()
                if nameLower:find("spine") or nameLower:find("chest") or nameLower:find("torso") then return part end
            end
        end
    end
    return nil
end

local function getLegParts(character)
    local legParts = {}
    if character then
        for _, part in ipairs(character:GetDescendants()) do
            if part:IsA("BasePart") then
                local nameLower = part.Name:lower()
                if nameLower:find("upperleg") or nameLower:find("lowerleg") or nameLower:find("foot") then
                    table.insert(legParts, part)
                end
            end
        end
    end
    return legParts
end

local function getRootPart(character)
    if character then
        return character:FindFirstChild("HumanoidRootPart")
    end
    return nil
end

local function getTargetPart(character, targetType)
    if targetType == "Head" then return getHeadPart(character)
    elseif targetType == "Chest" then return getChestPart(character)
    elseif targetType == "Legs" then
        local legs = getLegParts(character)
        if #legs > 0 then return legs[math.random(1, #legs)] end
    elseif targetName == "Root" then return getRootPart(character)
    else return getRootPart(character)
    end
end

local function getSkeletonBones(character)
    local bones = {}
    if not character then return bones end
    local root = getRootPart(character)
    if root then bones["HumanoidRootPart"] = {part = root, screenPos = worldToScreen(root.Position)} end
    local head = getHeadPart(character)
    if head then bones["Head"] = {part = head, screenPos = worldToScreen(head.Position)} end
    local chest = getChestPart(character)
    if chest then bones["Chest"] = {part = chest, screenPos = worldToScreen(chest.Position)} end
    local legs = getLegParts(character)
    if #legs > 0 then
        bones["LeftLeg"] = {part = legs[1], screenPos = worldToScreen(legs[1].Position)}
        if #legs > 1 then bones["RightLeg"] = {part = legs[2], screenPos = worldToScreen(legs[2].Position)} end
    end
    return bones
end

local function drawSkeleton(bones, thickness, color)
    if not bones["HumanoidRootPart"] or not bones["Head"] then return end
    local spine = bones["Chest"] or bones["HumanoidRootPart"]
    local head = bones["Head"]
    if spine.screenPos and head.screenPos then Draw.Line(spine.screenPos, head.screenPos, thickness, color) end
    if bones["HumanoidRootPart"].screenPos and spine.screenPos then Draw.Line(bones["HumanoidRootPart"].screenPos, spine.screenPos, thickness, color) end
    if bones["LeftLeg"] and bones["LeftLeg"].screenPos and bones["HumanoidRootPart"].screenPos then Draw.Line(bones["HumanoidRootPart"].screenPos, bones["LeftLeg"].screenPos, thickness, color) end
    if bones["RightLeg"] and bones["RightLeg"].screenPos and bones["HumanoidRootPart"].screenPos then Draw.Line(bones["HumanoidRootPart"].screenPos, bones["RightLeg"].screenPos, thickness, color) end
end

-- === FUNÇÃO DE TELEPORTE ===
local function teleportPlayer(x, y, z)
    if not LocalPlayer or not LocalPlayer.Character then return end
    local humanoidRootPart = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not humanoidRootPart then return end
    humanoidRootPart.CFrame = CFrame.new(x, y, z)
    print("Teleportado para: X=" .. x .. ", Y=" .. y .. ", Z=" .. z)
end

local function processChatCommand(message)
    local lowerMessage = message:lower()
    local prefix = Settings.TeleportPrefix:lower()
    if lowerMessage:sub(1, #prefix) == prefix then
        local commandAndArgs = lowerMessage:sub(#prefix + 1)
        local parts = commandAndArgs:split(" ")
        local command = parts[1]
        if command == Settings.TeleportCommand then
            local x, y, z
            if #parts == 4 then
                x = tonumber(parts[2]); y = tonumber(parts[3]); z = tonumber(parts[4])
            elseif #parts == 3 then
                x = tonumber(parts[2]); z = tonumber(parts[3]); y = Settings.DefaultY
            end
            if x ~= nil and y ~= nil and z ~= nil then
                teleportPlayer(x, y, z)
            else
                warn("Formato incorreto. Use: " .. Settings.TeleportPrefix .. Settings.TeleportCommand .. " x y z OU " .. Settings.TeleportPrefix .. Settings.TeleportCommand .. " x z")
            end
        end
    end
end

