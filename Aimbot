RunService.RenderStepped:Connect(function()
    -- Atualiza GUI
    if menuFrame then menuFrame.Visible = GUIConfig.MenuShow end

    local player, character = getLocalPlayerInfo()
    if not player or not character then
        IsAimKeyPressed = false
        AimbotConfig.Enabled = false -- Desativa aimbot se o jogador morrer
        CurrentTarget = nil
        return
    end

    local camera = workspace.CurrentCamera
    if not camera then return end

    -- Lógica da Tecla de Mira (adaptada para mobile)
    local currentAimKeyPressed = UserInputService:IsKeyDown(AimbotConfig.AimKey) -- Funciona se você conectar um teclado/mouse, ou se o executor simular

    if AimbotConfig.AimKeyMode == "Hold" then
        IsAimKeyPressed = currentAimKeyPressed
    elseif AimbotConfig.AimKeyMode == "Toggle" then
        if currentAimKeyPressed and not IsAimKeyPressed then
            AimToggleState = not AimToggleState
            AimbotConfig.Enabled = AimToggleState
        end
        IsAimKeyPressed = currentAimKeyPressed
    end

    -- Lógica de Aimbot
    if AimbotConfig.Enabled and IsAimKeyPressed then
        local targetPart, targetPlayer, targetScreenPos = findBestTarget()
        if targetPart then
            aimAt(targetPart, targetPlayer, targetScreenPos)
        else
            CurrentTarget = nil -- Limpa o alvo se nenhum for encontrado
        end
    else
        CurrentTarget = nil -- Limpa o alvo se desativado ou tecla não pressionada
    end

    -- Desenha indicadores na tela
    if camera then
        local screenCenter = Vector2.new(camera.ViewportSize.X / 2, camera.ViewportSize.Y / 2)

        if AimbotConfig.DrawFOV then
            -- Desenho simplificado do FOV com cruz
            Draw.Line(Vector2.new(screenCenter.X - AimbotConfig.FOV, screenCenter.Y), Vector2.new(screenCenter.X + AimbotConfig.FOV, screenCenter.Y), 2, AimbotConfig.FOVColor)
            Draw.Line(Vector2.new(screenCenter.X, screenCenter.Y - AimbotConfig.FOV), Vector2.new(screenCenter.X, screenCenter.Y + AimbotConfig.FOV), 2, AimbotConfig.FOVColor)
        end

        if AimbotConfig.DrawCrosshair then
            Draw.Line(Vector2.new(screenCenter.X - 5, screenCenter.Y), Vector2.new(screenCenter.X + 5, screenCenter.Y), 2, AimbotConfig.CrosshairColor)
            Draw.Line(Vector2.new(screenCenter.X, screenCenter.Y - 5), Vector2.new(screenCenter.X, screenCenter.Y + 5), 2, AimbotConfig.CrosshairColor)
        end

        if AimbotConfig.DrawTargetInfo and CurrentTarget and CurrentTargetScreenPos then
            local targetPlayerName = CurrentTarget.Name
            local distance = "???m"
            if character and character.HumanoidRootPart and CurrentTarget.Character and CurrentTarget.Character.HumanoidRootPart then
                distance = math.floor((CurrentTarget.Character.HumanoidRootPart.Position - character.HumanoidRootPart.Position).Magnitude) .. "m"
            end
            local infoText = targetPlayerName .. " (" .. distance .. ")"
            Draw.Text(infoText, Enum.Font.SourceSansBold, 14, Vector2.new(CurrentTargetScreenPos.X, CurrentTargetScreenPos.Y + 20), AimbotConfig.TargetInfoColor, true)
        end
    end
end)

-- Controles de Entrada (Mouse/Teclado se houver)
UserInputService.InputBegan:Connect(function(input, gameProcessedEvent)
    -- Lógica da Tecla de Mira (funciona se Delta mapeia o Button1 para clique)
    if input.UserInputType == Enum.UserInputType.MouseButton1 and AimbotConfig.AimKeyMode == "Hold" then
        if input.KeyCode == AimbotConfig.AimKey then
            AimbotConfig.Enabled = true
        end
    elseif input.UserInputType == Enum.UserInputType.MouseButton1 and AimbotConfig.AimKeyMode == "Toggle" then
        if input.KeyCode == AimbotConfig.AimKey then
            AimToggleState = not AimToggleState
            AimbotConfig.Enabled = AimToggleState
        end
    end

    -- Lógica para mover o menu
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        if IsDraggingMenu then IsDraggingMenu = false end
    end
end)

UserInputService.InputEnded:Connect(function(input, gameProcessedEvent)
    if input.UserInputType == Enum.UserInputType.MouseButton1 and AimbotConfig.AimKeyMode == "Hold" then
        if input.KeyCode == AimbotConfig.AimKey then
            AimbotConfig.Enabled = false
        end
    end
end)

