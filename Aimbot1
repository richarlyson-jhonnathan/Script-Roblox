-- 🧠 LÓGICA DO ESP — AJUSTE PERFEITO + ESQUELETO CORRIGIDO
local function ObterPontoMira(personagem)
    local cabeca = personagem:FindFirstChild("Head")
    local raiz = personagem:FindFirstChild("HumanoidRootPart")
    if Config.Aimbot.MiraCabeca and cabeca then return cabeca.Position end
    return raiz and raiz.Position or nil
end

-- ✅ ALTURA EXATA BASEADA NA SUA IMAGEM
local function PegarLimitesCorpo(personagem)
    local cabeca = personagem:FindFirstChild("Head")
    local raiz = personagem:FindFirstChild("HumanoidRootPart")
    if not cabeca or not raiz then return nil, nil end

    local topo = cabeca.Position + Vector3.new(0, cabeca.Size.Y/2, 0)
    -- Altura ajustada: 2.05 = encaixa exatamente nos pés
    local chao = topo - Vector3.new(0, 2.05, 0)
    return chao, topo
end

-- ✅ ESQUELETO FUNCIONAL PARA AMBOS OS MODELOS
local function ObterJuntas(char)
    -- Modelo antigo (Torso)
    if char:FindFirstChild("Torso") then
        return {
            {char.Head, char.Torso},
            {char.Torso, char["Left Arm"]}, {char.Torso, char["Right Arm"]},
            {char.Torso, char["Left Leg"]}, {char.Torso, char["Right Leg"]}
        }
    -- Modelo novo (UpperTorso/LowerTorso)
    elseif char:FindFirstChild("UpperTorso") then
        return {
            {char.Head, char.UpperTorso}, {char.UpperTorso, char.LowerTorso},
            {char.UpperTorso, char["LeftUpperArm"]}, {char["LeftUpperArm"], char["LeftLowerArm"]},
            {char.UpperTorso, char["RightUpperArm"]}, {char["RightUpperArm"], char["RightLowerArm"]},
            {char.LowerTorso, char["LeftUpperLeg"]}, {char["LeftUpperLeg"], char["LeftLowerLeg"]},
            {char.LowerTorso, char["RightUpperLeg"]}, {char["RightUpperLeg"], char["RightLowerLeg"]}
        }
    end
    return {}
end

local function EstaVisivel(alvoPos)
    local raio = Ray.new(Camera.CFrame.Position, (alvoPos - Camera.CFrame.Position).Unit * Config.Aimbot.DistanciaMax)
    local parte, ponto = workspace:FindPartOnRayWithIgnoreList(raio, {jogador.Character})
    return not parte or (alvoPos - ponto).Magnitude < 2
end

local function Limpar(chave) if Desenhos[chave] then Desenhos[chave]:Remove(); Desenhos[chave]=nil end end

-- ✅ DESENHO
local function ProcessarESP(alvo)
    local char = alvo.Character
    if not char then return end

    local infMundo, supMundo = PegarLimitesCorpo(char)
    if not infMundo or not supMundo then return end

    local infTela = Camera:WorldToScreenPoint(infMundo)
    local supTela = Camera:WorldToScreenPoint(supMundo)
    if infTela.Z < 0 or supTela.Z < 0 then return end

    local altura = math.abs(infTela.Y - supTela.Y)
    local largura = altura * 0.3
    local centroX = (infTela.X + supTela.X)/2
    local inicioX = centroX - (largura/2)

    -- CAIXA
    if Config.ESP.Caixa then
        local cx = Desenhos[alvo.Name.."_cx"] or Drawing.new("Square")
        cx.Visible = true; cx.Color = Color3.new(1,0,0); cx.Thickness = 1.5; cx.Filled = false
        cx.Position = Vector2.new(inicioX, supTela.Y)
        cx.Size = Vector2.new(largura, altura)
        Desenhos[alvo.Name.."_cx"] = cx
    else Limpar(alvo.Name.."_cx") end

    -- ✅ ESQUELETO AJUSTADO
    if Config.ESP.Esqueleto then
        local juntas = ObterJuntas(char)
        for i, par in pairs(juntas) do
            if par[1] and par[2] and par[1]:IsA("BasePart") and par[2]:IsA("BasePart") then
                local nome = alvo.Name.."_skel_"..i
                local ln = Desenhos[nome] or Drawing.new("Line")
                local p1 = Camera:WorldToScreenPoint(par[1].Position)
                local p2 = Camera:WorldToScreenPoint(par[2].Position)
                ln.Visible = true; ln.Color = Color3.new(0,1,0); ln.Thickness = 1.2
                ln.From = Vector2.new(p1.X, p1.Y); ln.To = Vector2.new(p2.X, p2.Y)
                Desenhos[nome] = ln
            end
        end
    else
        for k,_ in pairs(Desenhos) do if k:sub(1, #alvo.Name+7) == alvo.Name.."_skel_" then Limpar(k) end end
    end

    -- LINHA
    if Config.ESP.Linha then
        local ln = Desenhos[alvo.Name.."_ln"] or Drawing.new("Line")
        ln.Visible = true; ln.Color = Color3.new(1,0,0); ln.Thickness = 1.2
        ln.From = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y)
        ln.To = Vector2.new(centroX, supTela.Y + altura/2)
        Desenhos[alvo.Name.."_ln"] = ln
    else Limpar(alvo.Name.."_ln") end

    -- BARRA VIDA
    local hum = char:FindFirstChildWhichIsA("Humanoid")
    if hum and Config.ESP.Vida then
        local hp = hum.Health/hum.MaxHealth
        local fundo = Desenhos[alvo.Name.."_hpbg"] or Drawing.new("Square")
        local barra = Desenhos[alvo.Name.."_hp"] or Drawing.new("Square")
        fundo.Visible = true; fundo.Color = Color3.new(0.2,0.2,0.2); fundo.Thickness=1; fundo.Filled=true
        fundo.Position = Vector2.new(inicioX - 6, supTela.Y)
        fundo.Size = Vector2.new(3, altura)
        barra.Visible = true; barra.Color = hp>0.5 and Color3.new(0,1,0) or hp>0.25 and Color3.new(1,1,0) or Color3.new(1,0,0); barra.Thickness=1; barra.Filled=true
        barra.Position = Vector2.new(inicioX - 6, supTela.Y + altura*(1-hp))
        barra.Size = Vector2.new(3, altura*hp)
        Desenhos[alvo.Name.."_hpbg"] = fundo; Desenhos[alvo.Name.."_hp"] = barra
    else Limpar(alvo.Name.."_hpbg"); Limpar(alvo.Name.."_hp") end

    -- NOME
    if Config.ESP.Nome then
        local txt = Desenhos[alvo.Name.."_nm"] or Drawing.new("Text")
        txt.Visible = true; txt.Color = Color3.new(1,1,1); txt.Text = alvo.Name; txt.Font=2; txt.Size=11; txt.Center=true
        txt.Position = Vector2.new(centroX, supTela.Y - 10)
        Desenhos[alvo.Name.."_nm"] = txt
    else Limpar(alvo.Name.."_nm") end
end

local function PegarMelhorAlvo()
    local melhor, menorDist = nil, math.huge
    local centro = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= jogador and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            local pontoMira = ObterPontoMira(p.Character)
            if pontoMira then
                local dist = (pontoMira - Camera.CFrame.Position).Magnitude
                if dist <= Config.Aimbot.DistanciaMax then
                    local naTela = Camera:WorldToScreenPoint(pontoMira)
                    local distTela = (Vector2.new(naTela.X, naTela.Y) - centro).Magnitude
                    if distTela < menorDist then
                        if Config.AimCheck.Ativo and not EstaVisivel(pontoMira) then continue end
                        menorDist = distTela
                        melhor = p
                    end
                end
            end
        end
    end
    return melhor
end

-- 🔄 LOOP
RunService.RenderStepped:Connect(function()
    for k,_ in pairs(Desenhos) do local dono = k:match("^([^_]+)"); if dono and not Players:FindFirstChild(dono) then Limpar(k) end end
    for _, p in pairs(Players:GetPlayers()) do if p ~= jogador then ProcessarESP(p) end end
    if Config.Aimbot.Ativo then
        local alvo = PegarMelhorAlvo()
        if alvo and alvo.Character then
            local ponto = ObterPontoMira(alvo.Character)
            if ponto then Camera.CFrame = Camera.CFrame:Lerp(CFrame.new(Camera.CFrame.Position, ponto), 1 - Config.Aimbot.Suavidade) end
        end
    end
end)

