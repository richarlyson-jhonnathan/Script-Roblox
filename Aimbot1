RunService.RenderStepped:Connect(function()
    if not LocalPlayer or not LocalPlayer.Character then return end
    
    local camera = getCamera()
    if not camera then return end
    
    -- Verificar tecla de ativação
    local keyPressed = UserInputService:IsKeyDown(AimbotState.AimKey)
    
    if AimbotState.AimMode == "Hold" then
        IsKeyPressed = keyPressed
    elseif AimbotState.AimMode == "Toggle" then
        if keyPressed and not IsKeyPressed then
            ToggleState = not ToggleState
        end
        IsKeyPressed = keyPressed
    end
    
    -- AIMBOT
    if AimbotState.Enabled and IsKeyPressed then
        local target = findBestTarget()
        if target then
            aimAtTarget(target)
        end
    end
    
    -- DESENHAR ESP
    if AimbotState.DrawESP then
        for _, player in pairs(Players:GetPlayers()) do
            if player ~= LocalPlayer then
                drawESP(player)
            end
        end
    end
    
    -- DESENHAR FOV
    if AimbotState.DrawFOV then
        local screenCenter = Vector2.new(camera.ViewportSize.X / 2, camera.ViewportSize.Y / 2)
        drawCircle(screenCenter, AimbotState.FOV, AimbotState.FOVColor, 1)
    end
    
    -- DESENHAR CROSSHAIR
    if AimbotState.DrawCrosshair then
        local screenCenter = Vector2.new(camera.ViewportSize.X / 2, camera.ViewportSize.Y / 2)
        
        if AimbotState.CrosshairType == "Cross" then
            local size = AimbotState.CrosshairSize
            -- Desenhar cruz
        elseif AimbotState.CrosshairType == "Circle" then
            drawCircle(screenCenter, AimbotState.CrosshairSize, AimbotState.CrosshairColor, 2)
        end
    end
end)

