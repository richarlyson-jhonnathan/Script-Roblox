-- ═════════════════════════════════════════════════════════════
-- FUNÇÃO: Converter Mundo para Tela
-- ═════════════════════════════════════════════════════════════

local function worldToScreen(pos)
    if not pos then return nil end
    local camera = getCamera()
    if not camera then return nil end
    
    local success, screenPos = pcall(function()
        return camera:WorldToScreenPoint(pos)
    end)
    
    if success and screenPos then
        return Vector2.new(screenPos.X, screenPos.Y), screenPos.Z > 0
    end
    return nil, false
end

-- ═════════════════════════════════════════════════════════════
-- FUNÇÃO: Obter Parte do Alvo
-- ═════════════════════════════════════════════════════════════

local function getTargetPart(character, partType)
    if not character then return nil end
    
    if partType == "Head" then
        return character:FindFirstChild("Head") or character:FindFirstChild("HumanoidRootPart")
    elseif partType == "Chest" then
        return character:FindFirstChild("UpperTorso") or character:FindFirstChild("Torso") or character:FindFirstChild("HumanoidRootPart")
    elseif partType == "Root" then
        return character:FindFirstChild("HumanoidRootPart")
    end
    
    return character:FindFirstChild("HumanoidRootPart")
end

