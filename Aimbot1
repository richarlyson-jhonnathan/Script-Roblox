local function CriarBarraSuavidade(posY)
    local Fundo = Instance.new("Frame")
    Fundo.Size = UDim2.new(1,0,0,25); Fundo.Position = UDim2.new(0,0,0,posY)
    Fundo.BackgroundColor3 = Color3.new(0.25,0.25,0.3)
    Instance.new("UICorner", Fundo).CornerRadius = UDim.new(0,4); Fundo.Parent = Conteudo

    local Preenchido = Instance.new("Frame")
    Preenchido.Size = UDim2.new(Config.Aimbot.Suavidade,0,1,0)
    Preenchido.BackgroundColor3 = Color3.new(0.2,0.5,0.8)
    Instance.new("UICorner", Preenchido).CornerRadius = UDim.new(0,4); Preenchido.Parent = Fundo

    local TextoValor = Instance.new("TextLabel")
    TextoValor.Size = UDim2.new(1,0,1,0); TextoValor.BackgroundTransparency = 1
    TextoValor.Text = "Suavidade: "..string.format("%.2f", Config.Aimbot.Suavidade)
    TextoValor.TextColor3 = Color3.new(1,1,1); TextoValor.Font = Enum.Font.Gotham; TextoValor.TextSize = 10
    TextoValor.Parent = Fundo

    local Alterando = false
    local function Atualizar(posX)
        local v = math.clamp((posX - Fundo.AbsolutePosition.X)/Fundo.AbsoluteSize.X, 0.05, 0.95)
        Config.Aimbot.Suavidade = v
        Preenchido.Size = UDim2.new(v,0,1,0)
        TextoValor.Text = "Suavidade: "..string.format("%.2f", v)
    end
    Fundo.InputBegan:Connect(function(e) if e.UserInputType == Enum.UserInputType.MouseButton1 or e.UserInputType == Enum.UserInputType.Touch then Alterando=true; Atualizar(e.Position.X); e:Capture() end end)
    UserInputService.InputChanged:Connect(function(e) if Alterando then Atualizar(e.Position.X) end end)
    UserInputService.InputEnded:Connect(function() Alterando=false end)
end

