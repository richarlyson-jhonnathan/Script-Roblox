-- ═════════════════════════════════════════════════════════════
-- FUNÇÕES AUXILIARES
-- ═════════════════════════════════════════════════════════════

local function getCamera()
    return Workspace.CurrentCamera
end

local function worldToScreen(pos)
    if not pos then return nil, false end
    local camera = getCamera()
    if not camera then return nil, false end
    
    local success, screenPos = pcall(function()
        return camera:WorldToScreenPoint(pos)
    end)
    
    if success and screenPos then
        return Vector2.new(screenPos.X, screenPos.Y), screenPos.Z > 0
    end
    return nil, false
end

local function getTargetPart(character, partType)
    if not character then return nil end
    
    if partType == "Head" then
        return character:FindFirstChild("Head") or character:FindFirstChild("HumanoidRootPart")
    elseif partType == "Chest" then
        return character:FindFirstChild("UpperTorso") or character:FindFirstChild("Torso") or character:FindFirstChild("HumanoidRootPart")
    elseif partType == "Root" then
        return character:FindFirstChild("HumanoidRootPart")
    end
    
    return character:FindFirstChild("HumanoidRootPart")
end

-- ═════════════════════════════════════════════════════════════
-- FUNÇÃO: Encontrar Melhor Alvo
-- ═════════════════════════════════════════════════════════════

local function findBestTarget()
    local camera = getCamera()
    if not camera then return nil end
    
    local screenCenter = Vector2.new(camera.ViewportSize.X / 2, camera.ViewportSize.Y / 2)
    local fovRadius = AimbotState.FOV
    local closestDist = math.huge
    local bestTarget = nil
    
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            local humanoid = player.Character:FindFirstChild("Humanoid")
            local rootPart = player.Character:FindFirstChild("HumanoidRootPart")
            
            if humanoid and rootPart and humanoid.Health > 0 then
                pcall(function()
                    local distance = (rootPart.Position - LocalPlayer.Character.HumanoidRootPart.Position).Magnitude
                    
                    if distance <= AimbotState.MaxDistance then
                        local targetPart = getTargetPart(player.Character, AimbotState.TargetPart)
                        if targetPart then
                            local screenPos, onScreen = worldToScreen(targetPart.Position)
                            
                            if screenPos and onScreen then
                                local distToCenter = (screenPos - screenCenter).Magnitude
                                
                                if distToCenter < fovRadius and distToCenter < closestDist then
                                    closestDist = distToCenter
                                    bestTarget = {
                                        Player = player,
                                        Character = player.Character,
                                        TargetPart = targetPart,
                                        ScreenPos = screenPos,
                                        Distance = distance
                                    }
                                end
                            end
                        end
                    end
                end)
            end
        end
    end
    
    return bestTarget
end

-- ═════════════════════════════════════════════════════════════
-- FUNÇÃO: Apontar para Alvo
-- (Correção aplicada: não mover a câmera para a posição do personagem;
--  apenas rotacionar a câmera para olhar o alvo para evitar que os
--  braços sejam empurrados para frente da tela)
-- ═════════════════════════════════════════════════════════════

local function aimAtTarget(target)
    if not target or not target.TargetPart or not target.TargetPart.Parent then return end
    local camera = getCamera()
    if not camera then return end

    pcall(function()
        -- posição atual da câmera (não alteramos para evitar empurrar os braços)
        local camPos = camera.CFrame.Position
        local targetPos = target.TargetPart.Position
        local desiredCFrame = CFrame.new(camPos, targetPos)

        -- Interpolação suave para não saltar instantaneamente
        if type(AimbotState.SmoothAim) == "number" and AimbotState.SmoothAim > 0 and AimbotState.SmoothAim < 1 then
            camera.CFrame = camera.CFrame:Lerp(desiredCFrame, AimbotState.SmoothAim)
        else
            camera.CFrame = desiredCFrame
        end

        CurrentTarget = target
    end)
end

